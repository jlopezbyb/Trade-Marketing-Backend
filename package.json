  "main": "",
  "name": "backend-parking",
  "scripts": {
    "build": "pnpm build:validate && pnpm build:clean && pnpm build:generate",
    "build:clean": "rimraf ./build; exit 0",
    "build:validate": "tsc --noEmit",
    "build:generate": "swc ./src -d build --strip-leading-paths",
    "dev": "cross-env NODE_ENV=development tsnd --respawn --inspect=0.0.0.0:9229 -r tsconfig-paths/register ./src/index.ts",
    "dev:https": "cross-env NODE_ENV=development HTTPS_ENABLED=true tsnd --respawn --inspect=0.0.0.0:9229 -r tsconfig-paths/register ./src/index.ts",
    "format": "prettier --write \"./src/**/*.ts\"",
    "lint": "eslint . --ext .ts --quiet --fix --ignore-path .eslintignore",
    "prepare": "husky",
    "start": "node ./build/index.js",
    "test": "jest --config jest.config.js",
    "test:integration": "cross-env NODE_ENV=test jest --config jest.config.js",
    "test:e2e": "cross-env NODE_ENV=test jest --config jest.config.e2e.js"
  },
  "version": "0.1.0",
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node"
  }
